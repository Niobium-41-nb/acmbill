# ============================================
# ACM 报销材料管理系统 - 环境变量配置
# ============================================
# 复制此文件为 .env 并修改配置:
#   cp .env.example .env
# ============================================

# --- 数据库配置 ---
# 使用 Docker 部署时，DB_HOST 固定为 db（docker-compose 服务名）
# 注意: MYSQL_USER/MYSQL_PASSWORD 是 Docker MySQL 专有变量，
#       不要与远程 MySQL 的 DB_USER/DB_PASSWORD 混用
MYSQL_USER=acmbill
MYSQL_PASSWORD=acmbill123
DB_NAME=acmbill

# MySQL root 密码（仅 Docker 部署时需要，用于初始化）
DB_ROOT_PASSWORD=root123

# 以下变量仅用于本地/远程 MySQL 部署（非 Docker 时使用）
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password

# --- 应用密钥 ---
# 生产环境请务必修改为随机字符串
SECRET_KEY=your-secret-key-change-this-in-production

# --- 管理员账号 ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com

# --- 邮箱配置（用于发送注册/密码重置验证码）---
# 支持 QQ邮箱、163邮箱、Gmail 等 SMTP 服务
MAIL_SERVER=smtp.qq.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_authorization_code
MAIL_DEFAULT_SENDER=your_email@qq.com
